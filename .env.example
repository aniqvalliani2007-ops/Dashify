# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenRouter API Configuration (for AI-powered insights)
VITE_OPENROUTER_API_KEY=your-openrouter-api-key

# Site URL (for OpenRouter HTTP-Referer header)
# Production: https://your-domain.vercel.app
# Development: http://localhost:5173
VITE_SITE_URL=https://your-domain.vercel.app

# EmailJS Configuration (for contact form)
# Get these from https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=your-service-id
VITE_EMAILJS_TEMPLATE_ID=your-template-id
VITE_EMAILJS_PUBLIC_KEY=your-public-key

# -------------------------------------------------------
# GOOGLE OAUTH SETUP (Supabase Dashboard)
# -------------------------------------------------------
# 1. Go to Supabase Dashboard → Authentication → Providers → Google
# 2. Enable Google provider
# 3. Add your Google OAuth Client ID and Secret
#    (Get them from https://console.cloud.google.com → APIs & Services → Credentials)
# 4. In Google Cloud Console → OAuth consent screen → Authorized redirect URIs, add:
#    https://your-project-id.supabase.co/auth/v1/callback
# 5. In Supabase Dashboard → Authentication → URL Configuration, add to "Redirect URLs":
#    http://localhost:5173/auth/callback       (for local dev)
#    https://your-domain.vercel.app/auth/callback  (for production)
# -------------------------------------------------------